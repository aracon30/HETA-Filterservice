    "nodemailer": "^9.0.0",
    "pg": "^8.21.0",
    "react": "^19.2.7",
    "react-big-calendar": "^1.20.0",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/bcryptjs": "^2.4.6",
