# Required because some packages declare older peer ranges that don't yet list
# the latest majors (e.g. next-auth's optional nodemailer ^7 peer, react-big-calendar
# vs React 19). The lockfile is resolved this way, so `npm ci`/`npm install` must too.
legacy-peer-deps=true

# The server builds the app itself (next build needs typescript, tailwindcss,
# prisma for the postinstall `prisma generate`, etc. — all devDependencies).
# Force devDependencies even when NODE_ENV=production (pm2), otherwise `npm ci`
# omits them and the build / postinstall fail with "prisma: not found".
include=dev
