generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  SERVICE_MANAGER
  SERVICE_TECHNICIAN
  MAINTENANCE_MANAGER
  MAINTENANCE_TECHNICIAN
  BUYER
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  name            String
  password        String
  role            UserRole
  customerId      String?
  customer        Customer?        @relation(fields: [customerId], references: [id])
  active          Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  assignedJobs    ServiceJob[]     @relation("TechnicianJobs")
  userPermissions UserPermission[]
}

model UserPermission {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource  String
  canView   Boolean  @default(false)
  canCreate Boolean  @default(false)
  canEdit   Boolean  @default(false)
  canDelete Boolean  @default(false)
  scope     String   @default("all")
  updatedAt DateTime @updatedAt

  @@unique([userId, resource])
}

model RolePermission {
  id        String   @id @default(cuid())
  role      UserRole
  resource  String
  canView   Boolean  @default(false)
  canCreate Boolean  @default(false)
  canEdit   Boolean  @default(false)
  canDelete Boolean  @default(false)
  scope     String   @default("all")
  updatedAt DateTime @updatedAt

  @@unique([role, resource])
}

model Customer {
  id            String        @id @default(cuid())
  name          String
  contactName   String?
  email         String?
  phone         String?
  address       String?
  createdAt     DateTime      @default(now())
  plants        Plant[]
  jobs          ServiceJob[]
  opportunities Opportunity[]
  users         User[]
  invoices      Invoice[]
}

model Invoice {
  id            String      @id @default(cuid())
  customerId    String
  customer      Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  jobId         String?
  job           ServiceJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)
  invoiceNumber String?
  description   String?
  amount        Float?
  fileUrl       String
  fileName      String
  uploadedById  String
  createdAt     DateTime    @default(now())
}

model PlantType {
  id         String                   @id @default(cuid())
  value      String                   @unique
  label      String
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt
  items      PlantTypeChecklistItem[]
}

model PlantTypeChecklistItem {
  id          String    @id @default(cuid())
  plantTypeId String
  plantType   PlantType @relation(fields: [plantTypeId], references: [id], onDelete: Cascade)
  section     String
  label       String
  order       Int       @default(0)
}

model PlantChecklistOverride {
  id      String  @id @default(cuid())
  plantId String
  plant   Plant   @relation(fields: [plantId], references: [id], onDelete: Cascade)
  section String
  label   String
  order   Int     @default(0)
}

model Plant {
  id                String                   @id @default(cuid())
  name              String
  type              String
  serialNumber      String?
  location          String?
  installedAt       DateTime?
  buildYear         Int?
  description       String?
  contactPerson     String?
  manufacturer      String?
  model             String?
  customer          Customer                 @relation(fields: [customerId], references: [id])
  customerId        String
  jobPlants         ServiceJobPlant[]
  checklistOverrides PlantChecklistOverride[]
  checklistItems    ChecklistItem[]
}

model ServiceJobPlant {
  id      String     @id @default(cuid())
  job     ServiceJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId   String
  plant   Plant      @relation(fields: [plantId], references: [id])
  plantId String
  order   Int        @default(0)

  @@unique([jobId, plantId])
}

model ServiceJob {
  id              String            @id @default(cuid())
  orderNumber     String            @unique
  status          JobStatus         @default(PLANNED)
  scheduledAt     DateTime
  completedAt     DateTime?
  customer        Customer          @relation(fields: [customerId], references: [id])
  customerId      String
  plants          ServiceJobPlant[]
  technicianName       String?
  technicianId         String?
  technician           User?             @relation("TechnicianJobs", fields: [technicianId], references: [id])
  duration             Int               @default(480)
  vehicle              String?
  technicianSignature  String?
  customerSignature    String?
  description     String?
  findings        String?
  recommendations String?
  checklistItems  ChecklistItem[]
  invoices        Invoice[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model ChecklistItem {
  id       String     @id @default(cuid())
  label    String
  section  String?
  status   String     @default("open")
  checked  Boolean    @default(false)
  comment  String?
  photoUrl String?
  job      ServiceJob @relation(fields: [jobId], references: [id])
  jobId    String
  plantId  String?
  plant    Plant?     @relation(fields: [plantId], references: [id])
}

model Opportunity {
  id         String           @id @default(cuid())
  title      String
  value      Float?
  stage      OpportunityStage @default(IDENTIFIED)
  customer   Customer         @relation(fields: [customerId], references: [id])
  customerId String
  notes      String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
}

enum JobStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum OpportunityStage {
  IDENTIFIED
  QUALIFIED
  PROPOSAL
  WON
  LOST
}
