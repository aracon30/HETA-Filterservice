generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  SERVICE_MANAGER
  SERVICE_TECHNICIAN
  MAINTENANCE_MANAGER
  MAINTENANCE_TECHNICIAN
  BUYER
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  name            String
  password        String
  role            UserRole
  customerId      String?
  customer        Customer?        @relation(fields: [customerId], references: [id])
  phone           String?
  active              Boolean          @default(true)
  mustChangePassword  Boolean          @default(false)
  resetToken          String?
  resetTokenExpiry    DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  technicianAssignments ServiceJobTechnician[] @relation("TechnicianAssignments")
  userPermissions UserPermission[]
  defaultForPlants    Plant[]           @relation("PlantDefaultTechnician")
  externalPlants      PlantExternalUser[]
  contactLinks        Contact[]

  @@index([customerId])
}

model UserPermission {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource  String
  canView   Boolean  @default(false)
  canCreate Boolean  @default(false)
  canEdit   Boolean  @default(false)
  canDelete Boolean  @default(false)
  scope     String   @default("all")
  updatedAt DateTime @updatedAt

  @@unique([userId, resource])
}

model PlantExternalUser {
  id      String @id @default(cuid())
  plantId String
  userId  String
  plant   Plant  @relation(fields: [plantId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([plantId, userId])
}

model Customer {
  id            String        @id @default(cuid())
  name          String
  contactName   String?
  email         String?
  phone         String?
  address       String?
  createdAt     DateTime      @default(now())
  plants        Plant[]
  jobs          ServiceJob[]
  opportunities Opportunity[]
  users         User[]
  invoices      Invoice[]
  requests      PlantRequest[]
  hotels        Hotel[]
  sites         Site[]
  contacts      Contact[]
}

model Site {
  id         String    @id @default(cuid())
  customerId String
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name       String
  address    String?
  zip        String?
  city       String?
  note       String?
  plants     Plant[]
  contacts   Contact[]
  hotels     Hotel[]
  jobs       ServiceJob[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([customerId])
}

model Contact {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  siteId     String?
  site       Site?    @relation(fields: [siteId], references: [id], onDelete: Cascade)
  plantId    String?
  plant      Plant?   @relation(fields: [plantId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  name       String
  role       String?
  email      String?
  phone      String?
  isPrimary  Boolean  @default(false)
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([customerId])
  @@index([siteId])
  @@index([plantId])
  @@index([userId])
}

model Hotel {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  siteId     String?
  site       Site?    @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name       String
  address    String?
  phone      String?
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([customerId])
  @@index([siteId])
}

model Invoice {
  id            String      @id @default(cuid())
  customerId    String
  customer      Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  jobId         String?
  job           ServiceJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)
  invoiceNumber String?
  description   String?
  amount        Float?
  fileUrl       String
  fileName      String
  uploadedById  String
  createdAt     DateTime    @default(now())

  @@index([customerId])
  @@index([jobId])
}

model PlantType {
  id         String                   @id @default(cuid())
  value      String                   @unique
  label      String
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt
  items      PlantTypeChecklistItem[]
  partItems  PartTypeItem[]
}

model PartTypeItem {
  id          String    @id @default(cuid())
  plantTypeId String
  plantType   PlantType @relation(fields: [plantTypeId], references: [id], onDelete: Cascade)
  label       String
  partNumber  String?
  quantity    Int       @default(1)
  order       Int       @default(0)

  @@index([plantTypeId])
}

model PlantTypeChecklistItem {
  id          String    @id @default(cuid())
  plantTypeId String
  plantType   PlantType @relation(fields: [plantTypeId], references: [id], onDelete: Cascade)
  section     String
  label       String
  order       Int       @default(0)

  @@index([plantTypeId])
}

model PlantChecklistOverride {
  id      String  @id @default(cuid())
  plantId String
  plant   Plant   @relation(fields: [plantId], references: [id], onDelete: Cascade)
  section String
  label   String
  order   Int     @default(0)

  @@index([plantId])
}

model Plant {
  id                String                   @id @default(cuid())
  name              String
  type              String
  serialNumber      String?
  location          String?
  installedAt       DateTime?
  buildYear         Int?
  description       String?
  contactPerson     String?
  manufacturer      String?
  model             String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  customer          Customer                 @relation(fields: [customerId], references: [id])
  customerId        String
  site              Site?                    @relation(fields: [siteId], references: [id], onDelete: SetNull)
  siteId            String?
  contacts          Contact[]
  jobPlants         ServiceJobPlant[]
  checklistOverrides PlantChecklistOverride[]
  checklistItems    ChecklistItem[]
  materials         PlantMaterial[]
  opportunities     Opportunity[]
  documents         PlantDocument[]
  defaultTechnicianId String?
  defaultTechnician   User?             @relation("PlantDefaultTechnician", fields: [defaultTechnicianId], references: [id], onDelete: SetNull)
  externalUsers       PlantExternalUser[]
  requestPlants       PlantRequestPlant[]

  @@index([customerId])
  @@index([defaultTechnicianId])
  @@index([siteId])
}

enum DocumentType {
  INVOICE
  SERVICE_REPORT
  MANUAL
  DRAWING
  IMAGE
  OTHER
}

model PlantDocument {
  id             String       @id @default(cuid())
  plantId        String
  plant          Plant        @relation(fields: [plantId], references: [id], onDelete: Cascade)
  customerId     String
  type           DocumentType
  title          String
  description    String?
  fileUrl        String
  fileName       String
  fileSize       Int?
  mimeType       String?
  jobId          String?
  job            ServiceJob?  @relation(fields: [jobId], references: [id], onDelete: SetNull)
  uploadedById   String
  uploadedByName String
  createdAt      DateTime     @default(now())

  @@index([plantId])
  @@index([customerId])
  @@index([jobId])
}

model ServiceJobTechnician {
  id       String     @id @default(cuid())
  job      ServiceJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId    String
  user     User       @relation("TechnicianAssignments", fields: [userId], references: [id])
  userId   String
  userName String
  order    Int        @default(0)

  @@unique([jobId, userId])
  @@index([userId])
}

model ServiceJobPlant {
  id      String     @id @default(cuid())
  job     ServiceJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId   String
  plant   Plant      @relation(fields: [plantId], references: [id])
  plantId String
  order   Int        @default(0)

  @@unique([jobId, plantId])
  @@index([plantId])
}

model ServiceJob {
  id              String            @id @default(cuid())
  orderNumber     String            @unique
  status          JobStatus         @default(PLANNED)
  scheduledAt     DateTime
  completedAt     DateTime?
  customer        Customer          @relation(fields: [customerId], references: [id])
  customerId      String
  site            Site?             @relation(fields: [siteId], references: [id], onDelete: SetNull)
  siteId          String?
  plants          ServiceJobPlant[]
  technicians     ServiceJobTechnician[]
  vehicles        String[]
  duration        Int               @default(480)
  technicianSignature  String?
  customerSignature    String?
  description     String?
  findings        String?
  recommendations String?
  workTimeEntries Json?
  checklistItems  ChecklistItem[]
  invoices        Invoice[]
  opportunities   Opportunity[]
  jobMaterials    JobMaterial[]
  plantDocuments  PlantDocument[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([customerId])
  @@index([status, scheduledAt])
  @@index([siteId])
}

model PlantMaterial {
  id           String   @id @default(cuid())
  plantId      String
  plant        Plant    @relation(fields: [plantId], references: [id], onDelete: Cascade)
  label        String
  partNumber   String?
  quantity     Int      @default(1)
  status       String   @default("TO_ORDER")
  deliveryDate DateTime?
  notes        String?
  order        Int      @default(0)

  @@index([plantId])
}

model JobMaterial {
  id           String     @id @default(cuid())
  jobId        String
  job          ServiceJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  plantId      String
  plantName    String
  label        String
  partNumber   String?
  quantity     Int        @default(1)
  status       String     @default("TO_ORDER")
  deliveryDate DateTime?
  notes        String?
  order        Int        @default(0)

  @@index([jobId])
}

model ChecklistItem {
  id       String     @id @default(cuid())
  label    String
  section  String?
  status   String     @default("open")
  checked  Boolean    @default(false)
  comment  String?
  photoUrl String?
  job      ServiceJob @relation(fields: [jobId], references: [id])
  jobId    String
  plantId  String?
  plant    Plant?     @relation(fields: [plantId], references: [id])

  @@index([jobId])
  @@index([plantId])
}

model Opportunity {
  id               String            @id @default(cuid())
  title            String
  value            Float?
  stage            OpportunityStage  @default(IDENTIFIED)
  customer         Customer          @relation(fields: [customerId], references: [id])
  customerId       String
  notes            String?
  probability      Int?
  expectedCloseAt  DateTime?
  contactPerson    String?
  source           OpportunitySource @default(MANUAL)
  sourceJobId      String?
  sourceJob        ServiceJob?       @relation(fields: [sourceJobId], references: [id])
  plantId          String?
  plant            Plant?            @relation(fields: [plantId], references: [id])
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([customerId])
  @@index([stage])
}

enum JobStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum OpportunityStage {
  IDENTIFIED
  QUALIFIED
  PROPOSAL
  WON
  LOST
}

enum OpportunitySource {
  MANUAL
  SERVICE_REPORT
  CHECKLIST_NOK
}

enum RequestType {
  STOERUNG
  WARTUNG
  ANGEBOT
  INFORMATION
  SONSTIGES
}

enum RequestPriority {
  LOW
  NORMAL
  URGENT
  CRITICAL
}

enum RequestStatus {
  OPEN
  IN_REVIEW
  OFFER_SENT
  OFFER_ACCEPTED
  OFFER_REJECTED
  JOB_PLANNED
  REJECTED
  CLOSED
  ARCHIVED
}

model PlantRequest {
  id              String          @id @default(cuid())
  requestNumber   String          @unique
  title           String
  description     String
  type            RequestType     @default(SONSTIGES)
  priority        RequestPriority @default(NORMAL)
  status          RequestStatus   @default(OPEN)
  customerId      String
  customer        Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdById     String
  createdByName   String
  plants          PlantRequestPlant[]
  messages        PlantRequestMessage[]
  offerNumber     String?
  offerPdfs       PlantRequestOffer[]
  acceptedAt      DateTime?
  rejectedAt      DateTime?
  rejectionNote   String?
  serviceJobId    String?
  serviceJobNumber String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([customerId])
  @@index([status])
}

model PlantRequestPlant {
  id        String       @id @default(cuid())
  requestId String
  request   PlantRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  plantId   String
  plant     Plant        @relation(fields: [plantId], references: [id], onDelete: Cascade)
  plantName String

  @@unique([requestId, plantId])
}

model PlantRequestMessage {
  id                String       @id @default(cuid())
  requestId         String
  request           PlantRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  authorId          String
  authorName        String
  authorRole        String
  content           String
  statusChange      String?
  readByRequester   Boolean      @default(false)
  createdAt         DateTime     @default(now())

  @@index([requestId])
}

model PlantRequestOffer {
  id          String       @id @default(cuid())
  requestId   String
  request     PlantRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  offerNumber String
  fileUrl     String
  fileName    String
  uploadedById   String
  uploadedByName String
  createdAt   DateTime     @default(now())

  @@index([requestId])
}
