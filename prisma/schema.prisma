generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  SERVICE_MANAGER
  SERVICE_TECHNICIAN
  MAINTENANCE_MANAGER
  MAINTENANCE_TECHNICIAN
  BUYER
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  name            String
  password        String
  role            UserRole
  customerId      String?
  customer        Customer?        @relation(fields: [customerId], references: [id])
  active          Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  technicianAssignments ServiceJobTechnician[] @relation("TechnicianAssignments")
  userPermissions UserPermission[]
}

model UserPermission {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource  String
  canView   Boolean  @default(false)
  canCreate Boolean  @default(false)
  canEdit   Boolean  @default(false)
  canDelete Boolean  @default(false)
  scope     String   @default("all")
  updatedAt DateTime @updatedAt

  @@unique([userId, resource])
}

model RolePermission {
  id        String   @id @default(cuid())
  role      UserRole
  resource  String
  canView   Boolean  @default(false)
  canCreate Boolean  @default(false)
  canEdit   Boolean  @default(false)
  canDelete Boolean  @default(false)
  scope     String   @default("all")
  updatedAt DateTime @updatedAt

  @@unique([role, resource])
}

model Customer {
  id            String        @id @default(cuid())
  name          String
  contactName   String?
  email         String?
  phone         String?
  address       String?
  createdAt     DateTime      @default(now())
  plants        Plant[]
  jobs          ServiceJob[]
  opportunities Opportunity[]
  users         User[]
  invoices      Invoice[]
}

model Invoice {
  id            String      @id @default(cuid())
  customerId    String
  customer      Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  jobId         String?
  job           ServiceJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)
  invoiceNumber String?
  description   String?
  amount        Float?
  fileUrl       String
  fileName      String
  uploadedById  String
  createdAt     DateTime    @default(now())
}

model PlantType {
  id         String                   @id @default(cuid())
  value      String                   @unique
  label      String
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt
  items      PlantTypeChecklistItem[]
  partItems  PartTypeItem[]
}

model PartTypeItem {
  id          String    @id @default(cuid())
  plantTypeId String
  plantType   PlantType @relation(fields: [plantTypeId], references: [id], onDelete: Cascade)
  label       String
  partNumber  String?
  quantity    Int       @default(1)
  order       Int       @default(0)
}

model PlantTypeChecklistItem {
  id          String    @id @default(cuid())
  plantTypeId String
  plantType   PlantType @relation(fields: [plantTypeId], references: [id], onDelete: Cascade)
  section     String
  label       String
  order       Int       @default(0)
}

model PlantChecklistOverride {
  id      String  @id @default(cuid())
  plantId String
  plant   Plant   @relation(fields: [plantId], references: [id], onDelete: Cascade)
  section String
  label   String
  order   Int     @default(0)
}

model Plant {
  id                String                   @id @default(cuid())
  name              String
  type              String
  serialNumber      String?
  location          String?
  installedAt       DateTime?
  buildYear         Int?
  description       String?
  contactPerson     String?
  manufacturer      String?
  model             String?
  customer          Customer                 @relation(fields: [customerId], references: [id])
  customerId        String
  jobPlants         ServiceJobPlant[]
  checklistOverrides PlantChecklistOverride[]
  checklistItems    ChecklistItem[]
  materials         PlantMaterial[]
  opportunities     Opportunity[]
}

model ServiceJobTechnician {
  id       String     @id @default(cuid())
  job      ServiceJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId    String
  user     User       @relation("TechnicianAssignments", fields: [userId], references: [id])
  userId   String
  userName String
  order    Int        @default(0)

  @@unique([jobId, userId])
}

model ServiceJobPlant {
  id      String     @id @default(cuid())
  job     ServiceJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId   String
  plant   Plant      @relation(fields: [plantId], references: [id])
  plantId String
  order   Int        @default(0)

  @@unique([jobId, plantId])
}

model ServiceJob {
  id              String            @id @default(cuid())
  orderNumber     String            @unique
  status          JobStatus         @default(PLANNED)
  scheduledAt     DateTime
  completedAt     DateTime?
  customer        Customer          @relation(fields: [customerId], references: [id])
  customerId      String
  plants          ServiceJobPlant[]
  technicians     ServiceJobTechnician[]
  vehicles        String[]
  duration        Int               @default(480)
  technicianSignature  String?
  customerSignature    String?
  description     String?
  findings        String?
  recommendations String?
  workTimeEntries Json?
  checklistItems  ChecklistItem[]
  invoices        Invoice[]
  opportunities   Opportunity[]
  jobMaterials    JobMaterial[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model PlantMaterial {
  id           String   @id @default(cuid())
  plantId      String
  plant        Plant    @relation(fields: [plantId], references: [id], onDelete: Cascade)
  label        String
  partNumber   String?
  quantity     Int      @default(1)
  status       String   @default("TO_ORDER")
  deliveryDate DateTime?
  notes        String?
  order        Int      @default(0)
}

model JobMaterial {
  id           String     @id @default(cuid())
  jobId        String
  job          ServiceJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  plantId      String
  plantName    String
  label        String
  partNumber   String?
  quantity     Int        @default(1)
  status       String     @default("TO_ORDER")
  deliveryDate DateTime?
  notes        String?
  order        Int        @default(0)
}

model ChecklistItem {
  id       String     @id @default(cuid())
  label    String
  section  String?
  status   String     @default("open")
  checked  Boolean    @default(false)
  comment  String?
  photoUrl String?
  job      ServiceJob @relation(fields: [jobId], references: [id])
  jobId    String
  plantId  String?
  plant    Plant?     @relation(fields: [plantId], references: [id])
}

model Opportunity {
  id               String            @id @default(cuid())
  title            String
  value            Float?
  stage            OpportunityStage  @default(IDENTIFIED)
  customer         Customer          @relation(fields: [customerId], references: [id])
  customerId       String
  notes            String?
  probability      Int?
  expectedCloseAt  DateTime?
  contactPerson    String?
  source           OpportunitySource @default(MANUAL)
  sourceJobId      String?
  sourceJob        ServiceJob?       @relation(fields: [sourceJobId], references: [id])
  plantId          String?
  plant            Plant?            @relation(fields: [plantId], references: [id])
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

enum JobStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum OpportunityStage {
  IDENTIFIED
  QUALIFIED
  PROPOSAL
  WON
  LOST
}

enum OpportunitySource {
  MANUAL
  SERVICE_REPORT
  CHECKLIST_NOK
}
